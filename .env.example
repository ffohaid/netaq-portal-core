# ===== NETAQ Portal Environment Variables =====
# SECURITY: Never commit .env file to version control

# Database
DB_PASSWORD=YourSecureDbPassword

# Redis
REDIS_PASSWORD=YourSecureRedisPassword

# JWT
JWT_SECRET_KEY=YourSecureJwtKeyAtLeast32Characters

# Encryption (AES-256)
ENCRYPTION_KEY=YourSecureEncryptionKey

# SMTP (admin@netaq.pro)
SMTP_PASSWORD=YourSmtpPassword

# MinIO
MINIO_ROOT_USER=netaqadmin
MINIO_ROOT_PASSWORD=YourSecureMinioPassword
