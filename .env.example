# ============================================================
# NETAQ Portal — Environment Variables Template
# ============================================================
# SECURITY WARNING: Copy this file to .env and fill in real values.
# NEVER commit the .env file to version control.
# ============================================================

# ===== Database (SQL Server 2022) =====
DB_PASSWORD=YourSecureDbPassword_ChangeMe!

# ===== Redis 7 =====
REDIS_PASSWORD=YourSecureRedisPassword_ChangeMe!

# ===== JWT Authentication =====
JWT_SECRET_KEY=YourSecureJwtKeyAtLeast64CharactersLong_ChangeMe!

# ===== AES-256 Encryption =====
ENCRYPTION_KEY=YourSecure32CharEncryptionKey_ChangeMe!

# ===== SMTP (admin@netaq.pro) =====
SMTP_PASSWORD=YourSmtpPassword_ChangeMe!

# ===== MinIO (S3-Compatible Object Storage) =====
MINIO_ROOT_USER=netaqadmin
MINIO_ROOT_PASSWORD=YourSecureMinioPassword_ChangeMe!

# ===== Domain =====
DOMAIN=netaq.pro
CERTBOT_EMAIL=admin@netaq.pro
